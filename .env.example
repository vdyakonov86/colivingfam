BASE_DIR=/app/vpn_bot

# Telegram (revoke token if leaked; never commit real .env)
BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs of admins
TELEGRAM_ADMIN_IDS=123456789,987654321

# SQLite path (inside container use /data/app.db with compose volume)
DATABASE_PATH=/data/app.db
SEED_ROOMS_PATH=${BASE_DIR}/config/rooms_seed.json

MAX_RESIDENTS=50
TRAFFIC_RESET_PERIOD=30 # days

# 3x-ui panel: full base URL including WebBasePath, no trailing slash
# Example: https://colivingfam.icu:2254/YourWebBasePath
XUI_BASE_URL=https://example.com:2053/yourWebBasePath
XUI_USERNAME=panel_user
XUI_PASSWORD=panel_password
# Numeric inbound ID from panel (VLESS)
XUI_INBOUND_ID=1
# Optional: VLESS flow for new clients (e.g. xtls-rprx-vision); leave empty if unused
XUI_VLESS_FLOW=xtls-rprx-vision
XUI_LIMIT_IP=1
XUI_TOTAL_GB=10

# Public subscription URL prefix (sub server in 3x-ui may use another port/path).
# Example: https://colivingfam.icu:2096/sub/  — must end with /
# If empty, fallback is {XUI_BASE_URL}/sub/{subId}
SUBSCRIPTION_BASE_URL=

# TLS verify for panel HTTPS (set false only for debugging with self-signed)
XUI_VERIFY_TLS=true

# TTL одноразового кода привязки (минуты)
LINK_CODE_TTL_MINUTES=15
